@model HospitalSystem.ViewModels.DoctorProfileViewModel
@{
    ViewData["Title"] = "My Profile";
}

<div class="row justify-content-center my-4">
    <div class="col-lg-8">
        <div class="card shadow border-0 rounded-4">
            <div class="card-header bg-primary text-white border-bottom-0 text-center py-4 rounded-top-4">
                <i class="fa-solid fa-user-doctor fa-3x mb-3"></i>
                <h2 class="fw-bold mb-0">My Professional Profile</h2>
                <p class="opacity-75 mt-1 mb-0">Manage your personal details and consultation fee.</p>
            </div>
            <div class="card-body p-4 p-md-5 bg-white">
                
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show rounded-3 mb-4" role="alert">
                        <i class="fa-solid fa-circle-check me-2"></i> @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form asp-action="Profile" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3"></div>
                    
                    <h5 class="fw-bold text-dark border-bottom pb-2 mb-4"><i class="fa-regular fa-address-card text-primary me-2"></i> Personal Details</h5>
                    
                    <div class="row">
                        <div class="col-md-12 mb-4">
                            <label asp-for="FullName" class="form-label fw-bold"><i class="fa-regular fa-user text-muted me-1"></i> Full Name</label>
                            <input asp-for="FullName" class="form-control form-control-lg bg-light" />
                            <span asp-validation-for="FullName" class="text-danger small mt-1 d-block"></span>
                        </div>
                        
                        <div class="col-md-6 mb-4">
                            <label asp-for="Email" class="form-label fw-bold"><i class="fa-regular fa-envelope text-muted me-1"></i> Email</label>
                            <input asp-for="Email" class="form-control bg-light" type="email" />
                            <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                        </div>
                        
                        <div class="col-md-6 mb-4">
                            <label asp-for="Phone" class="form-label fw-bold"><i class="fa-solid fa-phone text-muted me-1"></i> Phone</label>
                            <input asp-for="Phone" class="form-control bg-light" />
                            <span asp-validation-for="Phone" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <h5 class="fw-bold text-dark border-bottom pb-2 mb-4 mt-3"><i class="fa-solid fa-stethoscope text-success me-2"></i> Professional Details</h5>

                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label asp-for="ConsultationFee" class="form-label fw-bold"><i class="fa-solid fa-money-bill-wave text-success me-1"></i> Consultation Fee ($)</label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text border-0 bg-light fw-bold text-success">$</span>
                                <input asp-for="ConsultationFee" type="number" step="0.01" class="form-control bg-light border-start-0 ps-0" />
                            </div>
                            <span asp-validation-for="ConsultationFee" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Bio" class="form-label fw-bold"><i class="fa-solid fa-pen-clip text-muted me-1"></i> Professional Bio</label>
                        <textarea asp-for="Bio" class="form-control bg-light" rows="5" placeholder="Briefly describe your experience and expertise..."></textarea>
                        <span asp-validation-for="Bio" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="d-grid mt-5">
                        <button type="submit" class="btn btn-primary btn-lg shadow-sm"><i class="fa-solid fa-floppy-disk me-2"></i> Save Profile Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}