@model IEnumerable<HospitalSystem.Models.User>
@{
    ViewData["Title"] = "Doctors List";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="fa-solid fa-user-doctor text-success me-2"></i> Registered Doctors</h2>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm mb-4">
        <i class="fa-solid fa-circle-check me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show rounded-3 shadow-sm mb-4">
        <i class="fa-solid fa-circle-exclamation me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="table-container shadow-sm border-0">
    <div class="table-responsive p-3">
        <table class="table table-custom align-middle table-hover">
            <thead>
                <tr>
                    <th><i class="fa-regular fa-user me-1"></i> Doctor Info</th>
                    <th><i class="fa-solid fa-microscope me-1"></i> Specialization</th>
                    <th><i class="fa-solid fa-right-to-bracket me-1"></i> Login Credentials</th>
                    <th><i class="fa-solid fa-wand-magic-sparkles me-1"></i> Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach(var doc in Model)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="bg-success text-white rounded-circle d-flex justify-content-center align-items-center me-3 shadow-sm" style="width: 45px; height: 45px; font-weight: bold; font-size: 1.2rem;">
                                    @((doc.FullName.Length > 0) ? doc.FullName.Substring(0, 1).ToUpper() : "?")
                                </div>
                                <div>
                                    <div class="fw-bold text-dark fs-6">Dr. @doc.FullName</div>
                                    <div class="small text-muted"><i class="fa-solid fa-envelope"></i> @(doc.Email ?? "No email")</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            @if(doc.DoctorProfile?.Specialization != null) {
                                <span class="badge bg-primary shadow-sm fs-6 d-block mb-1">@doc.DoctorProfile.Specialization.Name</span>
                                <span class="small fw-bold text-success">Fee: $@doc.DoctorProfile.ConsultationFee</span>
                            } else {
                                <span class="badge bg-danger shadow-sm fs-6"><i class="fa-solid fa-triangle-exclamation"></i> Not Assigned</span>
                            }
                        </td>
                        <td>
                            <div class="bg-light p-2 rounded border border-warning" style="display:inline-block; min-width: 200px;">
                                <div class="fw-bold text-dark small mb-1"><i class="fa-solid fa-at text-muted w-15px"></i> User: <span class="text-primary">@doc.Username</span></div>
                                <div class="fw-bold text-dark small"><i class="fa-solid fa-key text-muted w-15px"></i> Pass: <span class="text-danger">@doc.PasswordHash</span></div>
                            </div>
                        </td>
                        <td>
                            <div class="d-flex flex-column gap-2" style="max-width: 180px;">
                                <button type="button" class="btn btn-sm btn-outline-warning text-dark fw-bold" data-bs-toggle="modal" data-bs-target="#credModal-@doc.Id">
                                    <i class="fa-solid fa-user-lock"></i> Edit Credentials
                                </button>
                                <a asp-action="AssignSpecialization" asp-route-id="@doc.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="fa-solid fa-pen-to-square"></i> Edit Profile
                                </a>
                            </div>

                            <!-- Credentials Modal -->
                            <div class="modal fade" id="credModal-@doc.Id" tabindex="-1" aria-hidden="true">
                                <div class="modal-dialog">
                                    <div class="modal-content border-0 shadow">
                                        <div class="modal-header bg-warning text-dark border-0">
                                            <h5 class="modal-title fw-bold"><i class="fa-solid fa-user-lock"></i> Edit Credentials</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                        </div>
                                        <form asp-action="UpdateCredentials" method="post">
                                            <div class="modal-body p-4">
                                                <input type="hidden" name="id" value="@doc.Id" />
                                                <input type="hidden" name="returnUrl" value="/Admin/Doctors" />
                                                
                                                <div class="mb-3">
                                                    <label class="form-label fw-bold">Doctor Name</label>
                                                    <input type="text" class="form-control bg-light" value="@doc.FullName" disabled />
                                                </div>
                                                <div class="mb-3">
                                                    <label class="form-label fw-bold text-primary">Username</label>
                                                    <input type="text" name="username" class="form-control border-primary" value="@doc.Username" required />
                                                </div>
                                                <div class="mb-3">
                                                    <label class="form-label fw-bold text-danger">Password</label>
                                                    <input type="text" name="password" class="form-control border-danger" value="@doc.PasswordHash" required />
                                                </div>
                                            </div>
                                            <div class="modal-footer border-0 bg-light">
                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                <button type="submit" class="btn btn-warning fw-bold text-dark"><i class="fa-solid fa-save"></i> Save Changes</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>