@model IEnumerable<HospitalSystem.Models.Specialization>
@{
    ViewData["Title"] = "Specializations";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Specializations</h2>
    <a asp-action="CreateSpecialization" class="btn btn-primary">Add New Specialization</a>
</div>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Department</th>
        </tr>
    </thead>
    <tbody>
        @foreach(var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Name</td>
                <td>@(item.Department?.Name ?? "N/A")</td>
            </tr>
        }
    </tbody>
</table>