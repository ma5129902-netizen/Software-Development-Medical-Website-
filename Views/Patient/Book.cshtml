@model HospitalSystem.ViewModels.BookAppointmentViewModel
@{
    ViewData["Title"] = "Book Appointment";
}

<div class="row justify-content-center my-4">
    <div class="col-lg-8">
        <div class="card shadow border-0">
            <div class="card-header bg-white border-bottom border-light text-center py-4">
                <h2 class="fw-bold text-primary mb-0"><i class="fa-regular fa-calendar-plus"></i> Book an Appointment</h2>
                <p class="text-muted mt-2 mb-0">Follow the steps below to schedule your consultation</p>
            </div>
            <div class="card-body p-4 p-md-5">
                <form asp-action="Book" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3"></div>
                    
                    <div class="row bg-light p-4 rounded-4 mb-4">
                        <div class="col-md-6 mb-4">
                            <label asp-for="DepartmentId" class="form-label"><i class="fa-solid fa-building text-primary me-2"></i> 1. Select Department</label>
                            <select asp-for="DepartmentId" class="form-select form-select-lg" id="departmentSelect">
                                <option value="">-- Choose Department --</option>
                                @foreach (var dept in ViewBag.Departments)
                                {
                                    <option value="@dept.Id">@dept.Name</option>
                                }
                            </select>
                            <span asp-validation-for="DepartmentId" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-md-6 mb-4">
                            <label asp-for="SpecializationId" class="form-label"><i class="fa-solid fa-microscope text-success me-2"></i> 2. Select Specialization</label>
                            <select asp-for="SpecializationId" class="form-select form-select-lg" id="specializationSelect" disabled>
                                <option value="">-- Choose Specialization --</option>
                            </select>
                            <span asp-validation-for="SpecializationId" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-md-12 mb-2">
                            <label asp-for="DoctorId" class="form-label"><i class="fa-solid fa-user-doctor text-info me-2"></i> 3. Select Doctor</label>
                            <select asp-for="DoctorId" class="form-select form-select-lg" id="doctorSelect" disabled>
                                <option value="">-- Choose Doctor --</option>
                            </select>
                            <span asp-validation-for="DoctorId" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12 mb-4">
                            <label asp-for="AppointmentDate" class="form-label"><i class="fa-regular fa-clock text-warning me-2"></i> 4. Date & Time</label>
                            <input asp-for="AppointmentDate" class="form-control form-control-lg" type="datetime-local" />
                            <span asp-validation-for="AppointmentDate" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-md-12 mb-4">
                            <label asp-for="Notes" class="form-label"><i class="fa-solid fa-notes-medical text-danger me-2"></i> 5. Symptoms / Notes (Optional)</label>
                            <textarea asp-for="Notes" class="form-control form-control-lg" rows="3" placeholder="Briefly describe your symptoms..."></textarea>
                            <span asp-validation-for="Notes" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-3 mt-2">
                        <button type="submit" class="btn btn-primary btn-lg w-100 shadow"><i class="fa-solid fa-check-circle"></i> Confirm Booking</button>
                        <a asp-action="Index" class="btn btn-light btn-lg w-100 border"><i class="fa-solid fa-xmark"></i> Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const deptSelect = document.getElementById('departmentSelect');
            const specSelect = document.getElementById('specializationSelect');
            const docSelect = document.getElementById('doctorSelect');

            deptSelect.addEventListener('change', function () {
                const deptId = this.value;
                specSelect.innerHTML = '<option value="">-- Choose Specialization --</option>';
                docSelect.innerHTML = '<option value="">-- Choose Doctor --</option>';
                specSelect.disabled = true;
                docSelect.disabled = true;

                if (deptId) {
                    fetch(`/api/data/specializations/${deptId}`)
                        .then(response => response.json())
                        .then(data => {
                            data.forEach(spec => {
                                const option = document.createElement('option');
                                option.value = spec.id;
                                option.textContent = spec.name;
                                specSelect.appendChild(option);
                            });
                            specSelect.disabled = false;
                        });
                }
            });

            specSelect.addEventListener('change', function () {
                const specId = this.value;
                docSelect.innerHTML = '<option value="">-- Choose Doctor --</option>';
                docSelect.disabled = true;

                if (specId) {
                    fetch(`/api/data/doctors/${specId}`)
                        .then(response => response.json())
                        .then(data => {
                            data.forEach(doc => {
                                const option = document.createElement('option');
                                option.value = doc.id;
                                option.textContent = `Dr. ${doc.name} (Fee: $${doc.fee})`;
                                docSelect.appendChild(option);
                            });
                            docSelect.disabled = false;
                        });
                }
            });
        });
    </script>
}