@model IEnumerable<HospitalSystem.Models.Appointment>
@{
    ViewData["Title"] = "My Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-5 mt-3">
    <h2 class="fw-bold"><i class="fa-solid fa-list-check text-info me-2"></i> My Appointments</h2>
    <a asp-action="Book" class="btn btn-primary shadow-sm"><i class="fa-solid fa-plus"></i> Book New Appointment</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success border-0 shadow-sm alert-dismissible fade show rounded-3" role="alert">
        <i class="fa-solid fa-circle-check fs-5 me-2 align-middle"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="card shadow-sm border-0 bg-white rounded-4 text-center p-5 mt-4">
        <div class="card-body">
            <i class="fa-regular fa-folder-open fa-5x text-muted opacity-50 mb-3"></i>
            <h4 class="fw-bold text-dark">No Appointments Found</h4>
            <p class="text-muted">You haven't scheduled any appointments yet.</p>
            <a asp-action="Book" class="btn btn-primary mt-2">Book Your First Appointment</a>
        </div>
    </div>
}
else
{
    <div class="row">
        @foreach (var appt in Model)
        {
            <div class="col-lg-6 mb-4">
                <div class="card shadow-sm border-0 h-100 position-relative">
                    <!-- Status Ribbon indicator -->
                    <div class="position-absolute top-0 start-0 w-100" style="height: 6px; border-radius: 16px 16px 0 0; background-color: @(appt.Status == HospitalSystem.Models.AppointmentStatus.Pending ? "#f59e0b" : appt.Status == HospitalSystem.Models.AppointmentStatus.Confirmed ? "#3b82f6" : appt.Status == HospitalSystem.Models.AppointmentStatus.Completed ? "#10b981" : "#ef4444")"></div>
                    
                    <div class="card-body p-4 pt-4 mt-2">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <span class="badge @(appt.Status == HospitalSystem.Models.AppointmentStatus.Pending ? "bg-warning" : appt.Status == HospitalSystem.Models.AppointmentStatus.Confirmed ? "bg-info" : appt.Status == HospitalSystem.Models.AppointmentStatus.Completed ? "bg-success" : "bg-danger") mb-2 shadow-sm">
                                    @appt.Status.ToString().ToUpper()
                                </span>
                                <h4 class="card-title fw-bold text-dark mb-1">@appt.Doctor?.Specialization?.Name Consultation</h4>
                                <h6 class="text-primary fw-bold"><i class="fa-solid fa-user-doctor me-1"></i> Dr. @appt.Doctor?.User?.FullName</h6>
                            </div>
                            <div class="text-end bg-light p-3 rounded-3 border text-center" style="min-width: 100px;">
                                <div class="fs-4 fw-bold text-dark">@appt.AppointmentDate.ToString("dd")</div>
                                <div class="text-uppercase text-muted small fw-bold">@appt.AppointmentDate.ToString("MMM yyyy")</div>
                            </div>
                        </div>
                        
                        <hr class="text-muted opacity-25">
                        
                        <div class="row mt-3">
                            <div class="col-6 mb-2">
                                <p class="text-muted small mb-0"><i class="fa-regular fa-clock me-1"></i> Time</p>
                                <p class="fw-bold text-dark">@appt.AppointmentDate.ToString("hh:mm tt")</p>
                            </div>
                            <div class="col-6 mb-2">
                                <p class="text-muted small mb-0"><i class="fa-solid fa-money-bill-wave me-1"></i> Consultation Fee</p>
                                <p class="fw-bold text-success">$@appt.Doctor?.ConsultationFee</p>
                            </div>
                            @if (!string.IsNullOrEmpty(appt.Notes))
                            {
                                <div class="col-12 mt-2">
                                    <p class="text-muted small mb-0"><i class="fa-solid fa-comment-medical me-1"></i> Your Notes</p>
                                    <p class="fw-bold text-dark mb-0 border-start border-3 border-primary ps-3 py-1 bg-light rounded-end">@appt.Notes</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}